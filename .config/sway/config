	output eDP-1 {
		mode 3840x2160@60Hz
		position 0 0
		scale 1.75
	}
	output 'LG Electronics LG ULTRAGEAR 209MAJMGY572' {
		mode 2560x1440@179.960Hz
		position 2194 0
	}	
	output 'Philips Consumer Electronics Company PHL 278E1 0x000137E1' {
		mode 2560x1440@60Hz
		position 5120 0
		transform 90
		scale 1
	}
	output HEADLESS-1 {
		pos 2194,0
		transform 0
		mode 1200x2000@60Hz
		scale 1
