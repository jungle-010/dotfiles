#-critical	
	exec --no-startup-id dbus-update-activation-environment --all
#-general
	font pango:JetBrainsMono Nerd Font regular 12
	gaps inner 2
	gaps outer 2
	default_border pixel 2
	default_floating_border pixel 2
#-auto start
	exec gentoo-pipewire-launcher # pipewire [audio]
	exec mako # notification service [notifications]
	exec mullvad-vpn # vpn of choice [privacy]
	exec /home/jungle/.cargo/bin/awww-daemon # wallpaper daemon [wallpapers]
	exec /home/jungle/.cargo/bin/awww img /home/jungle/Pictures/wallhaven-6l5emq.png # set wallpaper [wallpapers] 
	exec /usr/libexec/polkit-gnome-authentication-agent-1 # gnome policy kit [polkit]
#-wallpaper
	# output * bg ~/.local/share/wallpaper.png fill
#-idle
	exec swayidle -w \
			timeout 300 'swaylock -f -c 000000' \
			timeout 600 'swaymsg "output * power off"' resume 'swaymsg "output * power on"' \
			before-sleep 'swaylock -f -c 000000'
#-status bar
	bar {
		swaybar_command waybar
	}
#-mouse cursor
	seat * xcursor_theme Adwaita 24
	seat seat0 xcursor_theme Adwaita 24

